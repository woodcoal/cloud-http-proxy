{
	"Logging": {
		"LogLevel": {
			"Default": "Information",
			"Microsoft.AspNetCore": "Warning"
		}
	},
	"AllowedHosts": "*",
	"ProxyConfig": {
		"BindIp": "0.0.0.0",
		"BindPort": 5000,
		"Timeout": 0,
		"MaxRequestBodySize": 10485760,
		"AllowedMethods": ["GET", "POST", "PUT", "DELETE", "HEAD", "OPTIONS", "PATCH"],
		"ProxyToken": "",
		"IpWhitelist": [],
		"FilteredHeaderPrefixes": ["cf-"],
		"FilteredSensitiveHeaders": [
			"~cookie",
			"~authorization",
			"proxy-authorization",
			"proxy-authenticate",
			"sec-websocket-key",
			"sec-websocket-protocol"
		],
		"UrlAccessControl": {
			"Mode": "none",
			"Urls": []
		},
		"UrlShortcuts": {},
		"ReplaceRules": [
			{
				"Type": "regex",
				"Pattern": "window\\.location\\.href\\s*=\\s*\"(/[^\"]+)\"",
				"Replacement": "window.location.href = \"/http://www.lvdingjia.com$1\"",
				"Direction": "response",
				"JsonMode": "whole",
				"Flags": "g"
			},
			{
				"Type": "regex",
				"Pattern": "(大沥|南海)",
				"Replacement": "【$1$】",
				"Direction": "response",
				"JsonMode": "whole",
				"Flags": "g",
				"Host": "lvdingjia.com"
			}
		],
		"HomePage": {
			"StatusCode": 404,
			"Content": "Not Found - Cloud Proxy"
		},
		"HtmlPathRewriteScope": ["link", "style", "script", "image", "media", "iframe", "form"],
		"DisableCache": true
	}
}
